# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/phishing-simulator

# JWT configuration
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRATION=7d

# URL of the simulation server (for inter-service communication)
SIMULATION_SERVER_URL=http://localhost:3001

# Shared API key for service-to-service auth with simulation server
SERVICE_API_KEY=change-me-to-a-random-api-key

# Server port (default: 3000)
PORT=3000
