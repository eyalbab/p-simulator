FROM node:20-alpine AS builder

WORKDIR /app

ARG VITE_MANAGEMENT_SERVER_URL=http://localhost:3000
ENV VITE_MANAGEMENT_SERVER_URL=${VITE_MANAGEMENT_SERVER_URL}

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

FROM nginx:alpine AS runner

COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
